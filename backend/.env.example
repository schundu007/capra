# Backend Environment Variables
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
PORT=3001

# PostgreSQL Database (Railway - shared with cariara)
DATABASE_URL=postgresql://user:password@host:port/database

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT Configuration (must match cariara backend)
JWT_SECRET_KEY=your-jwt-secret-same-as-cariara
JWT_ALGORITHM=HS256

# Stripe Configuration
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_xxx
STRIPE_PRICE_QUARTERLY_PRO=price_xxx
STRIPE_PRICE_DESKTOP=price_xxx
STRIPE_PRICE_ADDON=price_xxx
