{
  "manifest_version": 3,
  "name": "Ascend",
  "version": "2.1.0",
  "description": "Auto-detect coding problems and send to Ascend desktop app for instant solutions",
  "permissions": [
    "cookies",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.glider.ai/*",
    "https://*.gliderassessment.com/*",
    "https://*.lark.com/*",
    "https://*.larksuite.com/*",
    "https://*.feishu.cn/*",
    "https://*.hackerrank.com/*",
    "https://hr.gs/*",
    "https://*.leetcode.com/*",
    "https://*.coderpad.io/*",
    "https://*.codesignal.com/*",
    "https://*.codility.com/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.glider.ai/*",
        "https://*.gliderassessment.com/*",
        "https://*.lark.com/*",
        "https://*.larksuite.com/*",
        "https://*.feishu.cn/*",
        "https://*.hackerrank.com/*",
        "https://hr.gs/*",
        "https://*.leetcode.com/*",
        "https://*.coderpad.io/*",
        "https://*.codesignal.com/*",
        "https://*.codility.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
